{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "frontend/build" }
    },
    {
      "src": "api/upload.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/processed/[filename].py",
      "use": "@vercel/python"
    },
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    { "src": "/api/upload/?",        "dest": "api/upload.py"                   },
    { "src": "/api/mask-text/?",     "dest": "api/upload.py"                   },
    { "src": "/api/processed/(.*)",  "dest": "api/processed/[filename].py"     },
    { "src": "/api(.*)",             "dest": "api/index.py"                    },
    { "src": "/(.*)",                "dest": "frontend/build/index.html"       }
  ]
}
